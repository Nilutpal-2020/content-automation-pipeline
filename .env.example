# Environment
ENV=development
LOG_LEVEL=info
PORT=8080
# Five-field cron expression. Defaults to 08:00 in the server's local time.
CRON_SCHEDULE=0 8 * * *
# Best ranked items queued per category (AI, Backend, DevOps, Minimalist, Productivity, Tech News).
POSTS_PER_CATEGORY=3

# Notion Publishing Queue (Required)
NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_database_id

# AI Providers (Provide at least one)
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: defaults to gpt-5.4-mini.
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key
GEMINI_API_KEY=AIzaSy-your-gemini-api-key
